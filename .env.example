OPENAI_API_KEY=sk-...
OPENAI_COMPUTER_MODEL=gpt-5.4
APP_EXE=C:\src\klogg\build_root\output\RelWithDebInfo\cilogg.exe
APP_WORKDIR=C:\src\klogg\build_root\output\RelWithDebInfo
APP_ARGS=-n -m -l -dddd
APP_LOG_DIR=C:\src\klogg\build_root\output\RelWithDebInfo
APP_STATE_DIR=C:\Users\<you>\AppData\Local\cilogg
APP_DUMP_DIR=C:\src\klogg\build_root\output\RelWithDebInfo
MAIN_WINDOW_TITLE_REGEX=(?i)cilogg
APP_STATE_DUMP_ARG=--dump-state-json
QT_AUTOMATION_ENV_VAR=CILOGG_AUTOMATION
CILOGG_SAMPLE_LOG=C:\src\klogg\test_data\ansi_colors_example.txt
CILOGG_SMOKE_REQUIRE_COMPUTER_USE=1
WIN_GUI_CILOGG_SMOKE=0
